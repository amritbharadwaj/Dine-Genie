# Google Places API (New) — server-side only, never expose in client code
# Enable: https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Kimi API (Moonshot AI) — server-side only
# Get a key: https://platform.kimi.ai/
KIMI_API_KEY=your_kimi_api_key_here

# Optional aliases / overrides
# MOONSHOT_API_KEY=your_kimi_api_key_here
# KIMI_API_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=kimi-k2.6
