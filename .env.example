# Google Places API (New) — server-side only, never expose in client code
# Enable: https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Gemini API — server-side only (Google AI Studio or Google Cloud)
# Get a key: https://aistudio.google.com/apikey
# Enable Generative Language API in Google Cloud if using a GCP key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
